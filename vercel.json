{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "public/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/send-otp", "dest": "/api/send-otp.js" },
    { "src": "/api/verify-otp", "dest": "/api/verify-otp.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
